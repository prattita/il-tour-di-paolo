# Firebase (Project settings → Your apps → SDK setup → Config)
# Copy this file to `.env` and fill in values. Never commit `.env`.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only if you enabled Google Analytics for this web app in Firebase Console
# (same value as measurementId in the Firebase config snippet)
VITE_FIREBASE_MEASUREMENT_ID=

# Web Push (FCM) — Firebase Console → Project settings → Cloud Messaging → Web Push certificates
# Generate a key pair; paste the public key here (used by getToken in the app).
VITE_FIREBASE_VAPID_KEY=
