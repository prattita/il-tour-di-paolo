rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId));
    }

    function isGroupMember(groupId) {
      return request.auth != null
        && request.auth.uid in groupDoc(groupId).data.memberIds;
    }

    function isGroupOwner(groupId) {
      return request.auth != null
        && request.auth.uid == groupDoc(groupId).data.ownerId;
    }

    /** Multi-photo pending submission (Phase One Task 5): 1–3 items with url, path, dimensions. */
    function validPendingPhotoItem(p) {
      return p is map
        && p.keys().hasAll(['url', 'path', 'width', 'height'])
        && p.url is string
        && p.path is string
        && p.width is int
        && p.height is int;
    }

    function validPendingPhotosArray(photos) {
      return photos is list
        && photos.size() >= 1
        && photos.size() <= 3
        && validPendingPhotoItem(photos[0])
        && (photos.size() < 2 || validPendingPhotoItem(photos[1]))
        && (photos.size() < 3 || validPendingPhotoItem(photos[2]));
    }

    /** Group state after earlier ops in the same transaction/batch (required for self-join). */
    function groupAfterBatch(groupId) {
      return getAfter(/databases/$(database)/documents/groups/$(groupId));
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /groups/{groupId} {

      // Any signed-in user may fetch a group by document id (needed to join via invite before
      // membership exists; §7.3). Group ids are unlisted — `list` denied. Subcollections still
      // require membership except where rules say otherwise.
      allow get: if request.auth != null;
      allow list: if false;

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      // Self-join via invite: only `memberIds` may change, and exactly one id (the caller) is added.
      // Avoids brittle per-field == checks (e.g. description null vs missing) that can deny valid joins.
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerId
        || (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['memberIds'])
          && request.auth.uid in request.resource.data.memberIds
          && !(request.auth.uid in resource.data.memberIds)
          && request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        )
      );

      allow delete: if false;

      match /activities/{activityId} {
        allow read: if isGroupMember(groupId);
        allow write: if isGroupOwner(groupId);
      }

      match /members/{memberId} {
        allow read: if isGroupMember(groupId);
        // Join batch: group `memberIds` update must precede this create. `get()` sees pre-batch
        // state (user not listed yet) and always denies; `getAfter()` sees post-update state.
        allow create: if request.auth != null
          && request.auth.uid == memberId
          && request.auth.uid in groupAfterBatch(groupId).data.memberIds;
        allow update: if isGroupOwner(groupId)
          || (
            request.auth != null
            && request.auth.uid == memberId
            && isGroupMember(groupId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['selectedActivityIds'])
            && (
              request.resource.data.selectedActivityIds == null
              || request.resource.data.selectedActivityIds is list
            )
          )
          || (
            request.auth != null
            && request.auth.uid == memberId
            && isGroupMember(groupId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['avatarUrl'])
            && (
              request.resource.data.avatarUrl == null
              || request.resource.data.avatarUrl is string
            )
          );
        allow delete: if isGroupOwner(groupId);
      }

      match /pending/{pendingId} {
        // `get` on a missing doc has no `resource.data` — the old "submitter read" check denied
        // non-owners before their first submit. Allow `get` for the owner's queue, or any member
        // for paths `theirUid_*` (doc may or may not exist). `list` stays owner-only (approvals).
        allow get: if isGroupOwner(groupId)
          || (isGroupMember(groupId) && pendingId.matches('^' + request.auth.uid + '_.+'));

        allow list: if isGroupOwner(groupId);

        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.auth.uid in groupDoc(groupId).data.memberIds
          && pendingId == request.auth.uid + '_' + request.resource.data.activityId
          && validPendingPhotosArray(request.resource.data.photos)
          && (
            request.resource.data.avatarUrl == null
            || request.resource.data.avatarUrl is string
          );

        // Owner (queue) or submitter (Phase 9 withdraw). Submitter must still be a group member.
        allow delete: if isGroupOwner(groupId)
          || (
            request.auth != null
            && resource.data.userId == request.auth.uid
            && request.auth.uid in groupDoc(groupId).data.memberIds
          );

        allow update: if false;
      }

      match /feed/{postId} {
        allow read: if isGroupMember(groupId);

        // Owner-only create/delete (approval queue, system posts, moderation).
        allow create, delete: if isGroupOwner(groupId);

        // Owner: full post updates. Member: only `likes` or only `commentCount` (batched with comment writes).
        allow update: if isGroupOwner(groupId)
          || (
            isGroupMember(groupId)
            && (
              (
                request.resource.data.diff(resource.data).changedKeys().hasOnly(['likes'])
                && (request.resource.data.likes == null || request.resource.data.likes is list)
              )
              || (
                request.resource.data.diff(resource.data).changedKeys().hasOnly(['commentCount'])
                && request.resource.data.commentCount is int
                && request.resource.data.commentCount >= 0
              )
            )
          );

        match /comments/{commentId} {
          allow read: if isGroupMember(groupId);

          allow create: if isGroupMember(groupId)
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.displayName is string
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 500
            && (request.resource.data.avatarUrl == null || request.resource.data.avatarUrl is string)
            && request.resource.data.createdAt is timestamp;

          allow delete: if isGroupOwner(groupId)
            || (request.auth != null && resource.data.userId == request.auth.uid);

          allow update: if false;
        }
      }
    }

    match /invites/{inviteCode} {
      allow get: if request.auth != null;
      allow list: if false;

      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/groups/$(request.resource.data.groupId))
        && request.auth.uid == groupDoc(request.resource.data.groupId).data.ownerId;

      allow delete: if request.auth != null
        && request.auth.uid == groupDoc(resource.data.groupId).data.ownerId;

      allow update: if false;
    }
  }
}
