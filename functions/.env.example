# Copy to `functions/.env` (gitignored). Loaded when you deploy functions.
# No trailing slash. Example: https://il-tour-di-paolo.vercel.app
#
# https://firebase.google.com/docs/functions/config-env
WEB_APP_ORIGIN=

# Resend “from” address (must be a verified domain in Resend for production).
# Default onboarding@resend.dev only works for testing to your own inbox.
# RESEND_FROM=Il Tour di Paolo <notify@yourdomain.com>

# API key is NOT stored here — use a Google Cloud secret:
#   firebase functions:secrets:set RESEND_API_KEY
# Enable Secret Manager API if the CLI returns 403. Deployed functions declare this
# secret; without it, deploy can fail even if you are not sending email yet.
# Email postponed (no domain): see docs/phase-two/notifications-onepager.md → "Email (deferred)".
