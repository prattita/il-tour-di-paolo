rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /images/{submissionId}/{allPaths=**} {
      allow read, delete: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /feed/{postId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
